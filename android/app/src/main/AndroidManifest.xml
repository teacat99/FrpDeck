<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- frpc dial-out + WebView access to localhost. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Foreground service so frpc keeps running when the user leaves
         the app. data_sync is the most appropriate type per Android 14
         classification: we sync user data (frp tunnels) regardless of
         whether the user has the activity in foreground. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- API 33+ requires runtime POST_NOTIFICATIONS for the foreground
         service notification to be visible. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Battery optimisation opt-out helps frpc survive Doze on
         restrictive OEM ROMs. We request this explicitly via a settings
         intent; no signature permission needed. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Allow loopback HTTP from the WebView. By default Android
         WebView blocks http://127.0.0.1:* under Mixed Content — we
         declare an explicit network-security-config that exempts
         loopback. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name=".FrpDeckApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.FrpDeck"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:configChanges="orientation|screenSize|keyboardHidden|locale|layoutDirection"
            android:theme="@style/Theme.FrpDeck">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".service.FrpDeckForegroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

    </application>
</manifest>
