#!/bin/sh
# scripts/start-stop-status — DSM 7 service entry for FrpDeck.
# DSM contract: exit 0 on success / 1 on failure / 3 on "not running" (status only).
# Reference: https://help.synology.com/developer-guide/synology_package/scripts/

PID_FILE="${SYNOPKG_PKGVAR}/frpdeck.pid"
LOG_FILE="${SYNOPKG_PKGVAR}/frpdeck.log"
CONFIG_JSON="${SYNOPKG_PKGVAR}/config.json"
DEFAULT_PORT=18080

log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> "${LOG_FILE}"
}

ensure_dirs() {
    [ -d "${SYNOPKG_PKGVAR}" ] || mkdir -p "${SYNOPKG_PKGVAR}" 2>/dev/null
    [ -d "${SYNOPKG_PKGVAR}/data" ] || mkdir -p "${SYNOPKG_PKGVAR}/data" 2>/dev/null
}

ensure_config() {
    if [ ! -f "${CONFIG_JSON}" ]; then
        cat > "${CONFIG_JSON}" <<EOF
{
  "listen_port": ${DEFAULT_PORT}
}
EOF
    fi
}

# Read listen_port from config.json (user-editable from File Station).
# Falls back to DEFAULT_PORT when jq missing or value malformed.
get_listen_port() {
    port=""
    if [ -f "${CONFIG_JSON}" ]; then
        if command -v jq >/dev/null 2>&1; then
            port=$(jq -r '.listen_port // empty' "${CONFIG_JSON}" 2>/dev/null)
        else
            port=$(grep -o '"listen_port"[[:space:]]*:[[:space:]]*[0-9]\+' "${CONFIG_JSON}" \
                | grep -o '[0-9]\+' | head -n1)
        fi
    fi
    if [ -z "${port}" ] || [ "${port}" = "null" ]; then
        port="${DEFAULT_PORT}"
    fi
    echo "${port}"
}

is_running() {
    if [ -f "${PID_FILE}" ]; then
        pid=$(head -n 1 "${PID_FILE}" 2>/dev/null | tr -d '[:space:]')
        if [ -n "${pid}" ] && kill -0 "${pid}" 2>/dev/null; then
            return 0
        fi
        rm -f "${PID_FILE}"
    fi
    return 1
}

start_daemon() {
    if is_running; then
        log_msg "FrpDeck already running"
        return 0
    fi

    ensure_dirs
    ensure_config

    BIN="${SYNOPKG_PKGDEST}/bin/frpdeck-server"
    if [ ! -x "${BIN}" ]; then
        log_msg "ERROR: ${BIN} not found or not executable"
        return 1
    fi

    PORT=$(get_listen_port)
    log_msg "Starting FrpDeck on port ${PORT} with data dir ${SYNOPKG_PKGVAR}/data"

    # frpdeck-server reads FRPDECK_LISTEN / FRPDECK_DATA_DIR / FRPDECK_FRPCD_DRIVER
    # from env (see internal/config/config.go). embedded driver = bundled frp v0.68.1.
    FRPDECK_LISTEN=":${PORT}" \
    FRPDECK_DATA_DIR="${SYNOPKG_PKGVAR}/data" \
    FRPDECK_FRPCD_DRIVER="embedded" \
    FRPDECK_AUTH_MODE="${FRPDECK_AUTH_MODE:-password}" \
    nohup "${BIN}" >> "${LOG_FILE}" 2>&1 &
    PID=$!
    printf "%s" "${PID}" > "${PID_FILE}"
    log_msg "Started PID ${PID}"

    # Brief grace period catches early crashes (bad config, port collision)
    # so DSM Package Center can surface failure rather than silently mark as
    # running and leave the user wondering.
    sleep 1
    if ! is_running; then
        log_msg "ERROR: FrpDeck exited immediately; check ${LOG_FILE}"
        return 1
    fi
    return 0
}

stop_daemon() {
    if ! is_running; then
        log_msg "FrpDeck not running"
        rm -f "${PID_FILE}"
        return 0
    fi

    pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
    log_msg "Sending TERM to PID ${pid}"
    kill -TERM "${pid}" 2>/dev/null

    count=0
    while [ ${count} -lt 10 ]; do
        kill -0 "${pid}" 2>/dev/null || break
        sleep 1
        count=$((count + 1))
    done

    if kill -0 "${pid}" 2>/dev/null; then
        log_msg "TERM ignored after 10s, sending KILL to PID ${pid}"
        kill -KILL "${pid}" 2>/dev/null
        sleep 1
    fi

    rm -f "${PID_FILE}"
    log_msg "Stopped"
    return 0
}

case "$1" in
    start)
        start_daemon
        exit $?
        ;;
    stop)
        stop_daemon
        exit $?
        ;;
    status)
        if is_running; then exit 0; else exit 3; fi
        ;;
    log)
        echo "${LOG_FILE}"
        exit 0
        ;;
    *)
        echo "usage: $0 {start|stop|status|log}" >&2
        exit 1
        ;;
esac
