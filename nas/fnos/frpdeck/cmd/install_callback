#!/bin/bash
# Post-install: seed a writable config.json under the data-share so the
# user can edit listen_port from File Manager without SSH.
set -u

CONFIG_DIR="${TRIM_DATA_SHARE_PATHS%%:*}"
CONFIG_JSON="${CONFIG_DIR}/config.json"
DEFAULT_PORT="${TRIM_SERVICE_PORT:-18080}"

mkdir -p "${CONFIG_DIR}/data" 2>/dev/null || true

if [ ! -f "${CONFIG_JSON}" ]; then
    cat > "${CONFIG_JSON}" <<EOF
{
  "listen_port": ${DEFAULT_PORT}
}
EOF
fi

exit 0
